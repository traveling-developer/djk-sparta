---
import FirstBoardMember from "./contact/FirstBoardMember.astro";
import SecondBoardMember from "./contact/SecondBoardMember.astro";
import Treasurer from "./contact/Treasurer.astro";
import GoogleMap from "./GoogleMap.astro";
---

<section
  id="kontakt"
  class="bg-sparta-ink px-6 py-14 text-white md:px-14 md:py-22.5"
>
  <div class="grid grid-cols-1 items-start gap-15 md:grid-cols-[1fr_1.4fr]">
    <!-- Left: address + office -->
    <div class="contact-info">
      <div class="section-label">Kontakt &amp; Anfahrt</div>
      <h2 class="contact-headline">
        Dort, wo<br /><span class="contact-headline-red">Sparta</span> lebt.
      </h2>

      <address
        class="[&_a]:hover:text-sparta-red mb-7 font-mono text-[13px] leading-[1.9] not-italic [&_a]:no-underline"
      >
        DJK Sparta Noris Nürnberg e.V.<br />
        Wacholderweg 60<br />
        90441 Nürnberg · Weiherhaus<br /><br />
        <a href="tel:+4991148059 55">+49 911 480 59 55</a><br />
        <a href="mailto:info@djkspartanoris.de">info@djkspartanoris.de</a>
      </address>

      <div class="border-t border-white/12 pt-5">
        <div class="contact-office-label">Geschäftsstelle</div>
        <div class="contact-office-hours">
          Di &amp; Fr · 8 - 12 Uhr · oder nach Vereinbarung
        </div>
      </div>
    </div>

    <div>
      <GoogleMap {...Astro.props} />
    </div>
  </div>

  <!-- Below: contact persons -->
  <div class="contact-persons mt-15">
    <div class="contact-persons-label">Ansprechpartner</div>
    <div class="grid grid-cols-1 gap-3 lg:grid-cols-3">
      <FirstBoardMember />
      <SecondBoardMember />
      <Treasurer />
    </div>
  </div>
</section>

<style>
  .section-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #d81e28;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .contact-headline {
    font-family: "Oswald", "Arial Narrow", sans-serif;
    font-size: clamp(40px, 5vw, 64px);
    font-weight: 700;
    line-height: 0.95;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    margin: 0 0 28px;
    color: #fff;
  }
  .contact-headline-red {
    color: #d81e28;
  }

  .contact-office-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 8px;
  }
  .contact-office-hours {
    font-size: 14px;
  }

  /* Persons */
  .contact-persons-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 16px;
    font-weight: 600;
  }
</style>
