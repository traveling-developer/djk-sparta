---
import PersonCard from "./PersonCard.astro";

interface Props {
  title?: string;
  phone?: string;
  mail?: string;
  mobile?: string;
}

const { title = "", phone, mail, mobile } = Astro.props;

const match = title.match(/^(.*?)\s*\(([^)]+)\)\s*$/);
const name = match ? match[1].trim() : title;
const role = match ? match[2].trim() : undefined;
---

<PersonCard
  name={name}
  role={role}
  mail={mail}
  phone={phone}
  mobile={mobile}
  variant="dark"
/>
