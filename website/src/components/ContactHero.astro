---
import { Picture } from "astro:assets";
import spartanerImage from "../assets/spartaner.webp";
---

<section
  class="bg-sparta-paper border-sparta-ink px-6 pt-5 pb-15 md:px-14 md:pt-10"
>
  <div
    class="grid grid-cols-1 items-end gap-10 md:grid-cols-[1.4fr_1fr] md:gap-14"
  >
    <div>
      <h1
        class="font-display m-0 text-[clamp(56px,9vw,150px)] leading-[0.85] font-bold tracking-[-0.04em] uppercase md:text-[clamp(56px,8vw,150px)] 2xl:text-[clamp(56px,9vw,150px)]"
      >
        Schreib uns.<br /><span class="text-sparta-red italic"
          >Komm vorbei.</span
        >
      </h1>
      <p class="text-sparta-ink-soft mt-7 max-w-135 text-[17px] leading-[1.55]">
        Egal ob Probetraining, Mitgliedschaft oder Pressefrage, wir antworten in
        der Regel innerhalb von 48 Stunden.
      </p>
    </div>
    <div
      class="mx-auto hidden max-w-40 self-center md:block md:max-w-45 lg:max-w-55 2xl:max-w-60"
    >
      <Picture
        src={spartanerImage}
        formats={["webp"]}
        fallbackFormat="webp"
        alt="DJK Sparta Noris"
        widths={[300, 600]}
        sizes="300px"
        class="block h-auto w-full"
      />
    </div>
  </div>
</section>
