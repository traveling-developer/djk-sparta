---
import { Picture } from "astro:assets";
import spartanerImage from "../assets/spartaner.webp";
---

<section class="bg-sparta-paper">
  <div class="mx-auto max-w-450 px-6 py-10 md:px-14 md:pt-5 md:pb-15">
    <div class="grid grid-cols-1 gap-x-8 gap-y-5 md:grid-cols-2">
      <h1
        class="font-display text-sparta-ink text-[clamp(80px,12vw,220px)] leading-[0.85] font-bold tracking-[-0.04em] uppercase md:mt-5 md:text-[clamp(80px,11vw,220px)] xl:mt-0 2xl:text-[clamp(80px,12vw,220px)]"
      >
        Wir sind<br />
        <span class="text-sparta-red italic">Sparta.</span>
      </h1>

      <!-- Row 1 right: image -->
      <div
        class="mx-auto mb-8 hidden max-w-40 self-center md:block md:max-w-45 lg:max-w-55 2xl:max-w-75"
      >
        <Picture
          src={spartanerImage}
          formats={["webp"]}
          alt="DJK Sparta Noris"
          widths={[300, 600]}
          sizes="300px"
          class="block h-auto w-full"
        />
      </div>

      <!-- Row 2 left: intro + CTA, centered relative to stats -->
      <div class="flex flex-col justify-center">
        <div
          class="text-sparta-red mb-3.5 text-xl font-semibold tracking-[2px] uppercase"
        >
          Willkommen
        </div>
        <p class="mb-7 text-[17px] leading-[1.55] text-[#1a1a1d]">
          Dein Traditionsverein im Nürnberger Süden. Wir verbinden Freundschaft,
          Familie, Tradition und soziales Engagement mit dem Sport — seit über
          hundert Jahren.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="#abteilungen"
            class="bg-sparta-ink px-5 py-3.25 text-xs font-bold tracking-[1px] text-white uppercase no-underline"
            >Abteilungen ansehen</a
          >
        </div>
      </div>

      <!-- Row 2 right: stats -->
      <div class="md:pl-25">
        {
          [
            ["1918", "Gegründet im Nürnberger Süden"],
            ["5", "Abteilungen unter einem Dach"],
            ["490+", "Aktive Mitglieder"],
            ["18", "Mannschaften im Spielbetrieb"],
          ].map(([num, label]) => (
            <div class="border-sparta-line flex items-baseline justify-between border-t py-3.5">
              <span class="font-display text-sparta-ink text-[32px] font-bold">
                {num}
              </span>
              <span class="text-sparta-mute max-w-35 text-right text-xs leading-[1.3]">
                {label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
