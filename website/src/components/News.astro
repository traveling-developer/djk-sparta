---
import { latestNews, latestTableTennisNews } from "../lib/news";
import { createSlug } from "../lib/convenience";

type Category = "table-tennis";

interface Props {
  category?: Category;
  eyebrow?: string;
  title?: string;
}

const {
  category,
  eyebrow = "Aus dem Verein",
  title = "Aktuelles",
} = Astro.props;

const categoryLabel: Record<string, string> = {
  "general": "Allgemein",
  "soccer": "Fußball",
  "health-sport": "Gesundheitssport",
  "indiaca": "Indiaca",
  "tennis": "Tennis",
  "table-tennis": "Tischtennis",
};

function formatDate(iso: string | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  return d.toLocaleDateString("de-DE", { day: "2-digit", month: "2-digit", year: "numeric" });
}

const source = category === "table-tennis" ? latestTableTennisNews : latestNews;
type NewsWithImage = (typeof source)[number] & { imageUrl?: string };

const news = source.slice(0, 5) as NewsWithImage[];
const featured = news[0];
const secondary = news.slice(1, 3);
const third = news.slice(3, 5);
---

{news.length > 0 && (
  <section
    id="news"
    class="bg-sparta-paper px-6 py-14 md:px-14 md:py-10"
  >
    <!-- Section header -->
    <div
      class="border-sparta-ink mb-10 flex items-end justify-between border-b-2 pb-4.5"
    >
      <div>
        <div class="section-label">{eyebrow}</div>
        <h2
          class="font-display text-sparta-ink m-0 text-[clamp(48px,6vw,72px)] font-bold uppercase leading-none tracking-[-0.02em]"
        >
          {title}
        </h2>
      </div>
      <!-- <a
        href="/news"
        class="font-semibold hover:text-sparta-red whitespace-nowrap text-[13px] no-underline hover:opacity-100"
        >Alle Meldungen →</a> -->
    </div>

    <div class="news-grid">
      <!-- Featured article -->
      {featured && (
        <article class="news-featured">
          <div class="news-meta">
            <span class="news-cat">{categoryLabel[featured.category ?? ""] ?? featured.category}</span>
            <span class="news-date">· {formatDate(featured.releaseDate)}</span>
          </div>
          <h3 class="news-featured-title">
            <a href={`/news/${createSlug(featured.title!)}`}>{featured.title}</a>
          </h3>
          <p class="news-featured-body">
            {featured.content?.split(" ").slice(0, 70).join(" ")}…
          </p>
        </article>
      )}

      <!-- Secondary articles -->
      <div class="flex flex-col">
        {secondary.map((n, i) => (
          <article class={`news-secondary-item${i < secondary.length - 1 ? " has-border" : ""}`}>
            <div class="news-meta">
              <span class="news-cat">{categoryLabel[n.category ?? ""] ?? n.category}</span>
              <span class="news-date">· {formatDate(n.releaseDate)}</span>
            </div>
            <h3 class="news-secondary-title">
              <a href={`/news/${createSlug(n.title!)}`}>{n.title}</a>
            </h3>
            <p class="news-secondary-body">
              {n.content?.split(" ").slice(0, 18).join(" ")}…
            </p>
          </article>
        ))}
      </div>

      <!-- Third articles -->
      <div class="hidden flex-col lg:flex">
        {third.map((n, i) => (
          <article class={`news-secondary-item${i < third.length - 1 ? " has-border" : ""}`}>
            <div class="news-meta">
              <span class="news-cat">{categoryLabel[n.category ?? ""] ?? n.category}</span>
              <span class="news-date">· {formatDate(n.releaseDate)}</span>
            </div>
            <h3 class="news-secondary-title">
              <a href={`/news/${createSlug(n.title!)}`}>{n.title}</a>
            </h3>
            <p class="news-secondary-body">
              {n.content?.split(" ").slice(0, 18).join(" ")}…
            </p>
          </article>
        ))}
      </div>

    </div>
  </section>
)}

<style>
  .section-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #D81E28;
    font-weight: 600;
    margin-bottom: 8px;
  }



  /* 3-col grid */
  .news-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 36px;
    align-items: start;
  }

  /* Meta */
  .news-meta {
    display: flex;
    gap: 8px;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 10px;
  }
  .news-cat {
    color: #D81E28;
  }
  .news-date {
    color: #6A6A70;
  }

  /* Featured */
  .news-featured-img {
    height: 320px;
    overflow: hidden;
    margin-bottom: 20px;
    background: #E4E2DD;
  }
  .news-featured-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .news-featured-placeholder {
    height: 320px;
    margin-bottom: 20px;
    background: repeating-linear-gradient(
      135deg,
      #D81E28 0 14px,
      #A51119 14px 15px
    );
  }

  .news-featured-title {
    font-family: "Oswald", "Arial Narrow", sans-serif;
    font-size: 28px;
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 14px;
    color: #0C0C0E;
  }
  .news-featured-title a {
    color: inherit;
    text-decoration: none;
  }
  .news-featured-title a:hover {
    color: #D81E28;
    opacity: 1;
  }

  .news-featured-body {
    font-size: 15px;
    color: #1A1A1D;
    line-height: 1.6;
    margin: 0;
  }

  /* Secondary */
  .news-secondary-item {
    padding-bottom: 24px;
    margin-bottom: 24px;
  }
  .news-secondary-item.has-border {
    border-bottom: 1px solid #E4E2DD;
  }

  .news-secondary-title {
    font-family: "Oswald", "Arial Narrow", sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 8px;
    color: #0C0C0E;
  }
  .news-secondary-title a {
    color: inherit;
    text-decoration: none;
  }
  .news-secondary-title a:hover {
    color: #D81E28;
    opacity: 1;
  }

  .news-secondary-body {
    font-size: 13px;
    color: #6A6A70;
    line-height: 1.5;
    margin: 0;
  }

  /* Sidebar */
  .news-sidebar {
    background: #0C0C0E;
    color: #fff;
    padding: 24px;
  }

  .sidebar-label {
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #D81E28;
    font-weight: 600;
    margin-bottom: 14px;
  }

  .news-sidebar .news-cat {
    color: #D81E28;
  }
  .news-sidebar .news-date {
    color: rgba(255, 255, 255, 0.5);
  }

  .news-sidebar-title {
    font-family: "Oswald", "Arial Narrow", sans-serif;
    font-size: 20px;
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 10px;
    color: #fff;
  }
  .news-sidebar-title a {
    color: inherit;
    text-decoration: none;
  }
  .news-sidebar-title a:hover {
    color: #D81E28;
    opacity: 1;
  }

  .news-sidebar-body {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
    margin: 0 0 20px;
  }

  .news-cta-box p {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
    margin: 0 0 16px;
  }

  .news-cta-btn {
    display: inline-block;
    padding: 10px 16px;
    background: #D81E28;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    text-decoration: none;
    margin-bottom: 20px;
  }

  .sidebar-all-link {
    display: block;
    margin-top: 16px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #D81E28;
    text-decoration: none;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: 14px;
  }

  @media (max-width: 1024px) {
    .news-grid {
      grid-template-columns: 1fr 1fr;
    }
    .news-sidebar {
      display: none;
    }
  }

  @media (max-width: 700px) {
    .news-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
