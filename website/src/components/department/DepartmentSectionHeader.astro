---
type Variant = "light" | "dark";

interface Props {
  eyebrow: string;
  title: string;
  aside?: string;
  variant?: Variant;
  class?: string;
}

const {
  eyebrow,
  title,
  aside,
  variant = "light",
  class: className = "",
} = Astro.props;

const isDark = variant === "dark";
const borderClass = isDark ? "border-white/20" : "border-sparta-ink";
const titleClass = isDark ? "text-white" : "text-sparta-ink";
const asideClass = isDark ? "text-white/55" : "text-sparta-mute";
---

<div
  class={`mb-9 flex flex-col items-start justify-between gap-4 border-b-2 pb-4.5 md:flex-row md:items-end ${borderClass} ${className}`}
>
  <div>
    <div
      class="text-sparta-red mb-2 text-[11px] font-semibold tracking-[2px] uppercase"
    >
      {eyebrow}
    </div>
    <h2
      class={`font-display m-0 text-[clamp(36px,5vw,64px)] leading-none font-bold tracking-[-1px] uppercase ${titleClass}`}
    >
      <slot name="title">{title}</slot>
    </h2>
  </div>
  {
    aside && (
      <div class={`max-w-70 text-[13px] md:text-right ${asideClass}`}>
        {aside}
      </div>
    )
  }
</div>
