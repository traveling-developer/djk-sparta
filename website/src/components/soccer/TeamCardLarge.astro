---
interface Props {
  name: string;
  league: string;
  place?: string;
  played?: number;
  w?: number;
  d?: number;
  l?: number;
  pts?: number | string;
  link?: string;
  linkLabel?: string;
}

const {
  name,
  league,
  place,
  played,
  w,
  d,
  l,
  pts,
  link,
  linkLabel = "Mehr erfahren",
} = Astro.props;

const dash = "—";
const fmt = (n: number | undefined) => (n === undefined ? dash : n);

const detailStats: [string, string | number][] = [
  ["Sp", fmt(played)],
  ["S", fmt(w)],
  ["U", fmt(d)],
  ["N", fmt(l)],
];

const isExternal = link ? /^https?:\/\//.test(link) : false;
---

<article
  class="text-sparta-ink border-sparta-line flex flex-col overflow-hidden border bg-white"
>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-display m-0 text-[28px] leading-none font-bold uppercase">
      {name}
    </h3>
    <div class="mt-1.5 mb-5 text-[13px] opacity-70">{league}</div>

    <div class="border-sparta-line grid grid-cols-2 border-t pt-5">
      <div class="pr-5">
        <div
          class="font-display text-[clamp(48px,7vw,72px)] leading-none font-bold tracking-[-2px]"
        >
          {place ?? dash}
        </div>
        <div
          class="mt-2 font-mono text-[10px] tracking-[2px] uppercase opacity-55"
        >
          Tabellenplatz
        </div>
      </div>
      <div class="border-sparta-line border-l pl-5">
        <div
          class="font-display text-sparta-red text-[clamp(48px,7vw,72px)] leading-none font-bold tracking-[-2px]"
        >
          {pts ?? dash}
        </div>
        <div
          class="mt-2 font-mono text-[10px] tracking-[2px] uppercase opacity-55"
        >
          Punkte
        </div>
      </div>
    </div>

    <div class="border-sparta-line mt-5 grid grid-cols-4 gap-2 border-t pt-4">
      {
        detailStats.map(([k, v]) => (
          <div>
            <div class="font-mono text-[10px] tracking-[1.5px] uppercase opacity-55">
              {k}
            </div>
            <div class="font-display mt-1 text-[18px] leading-none font-bold">
              {v}
            </div>
          </div>
        ))
      }
    </div>

    {!link && <div class="border-sparta-line mt-5 border-t" />}

    {
      link && (
        <a
          href={link}
          target={isExternal ? "_blank" : undefined}
          rel={isExternal ? "noopener noreferrer" : undefined}
          class="font-display text-sparta-red border-sparta-line mt-5 flex items-center justify-between gap-2 border-t pt-5 text-[11px] font-bold tracking-[2px] uppercase no-underline hover:opacity-70"
        >
          <span>{linkLabel}</span>
          <span aria-hidden="true">→</span>
        </a>
      )
    }
  </div>
</article>
