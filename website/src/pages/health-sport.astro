---
import Layout from "../layouts/Layout.astro";
import DepartmentHero from "../components/department/DepartmentHero.astro";
import DepartmentSectionHeader from "../components/department/DepartmentSectionHeader.astro";
import DepartmentCTA from "../components/department/DepartmentCTA.astro";
import CoachesGrid from "../components/department/CoachesGrid.astro";

interface Slot {
  day: string;
  time: string;
  location: string;
}

interface Offer {
  title: string;
  slots: Slot[];
}

const offers: Offer[] = [
  {
    title: "Herzsport mit Verordnung",
    slots: [
      {
        day: "Mittwoch",
        time: "14:00 – 15:00 & 15:15 – 16:15",
        location: "Großer Saal, Bleiweißzentrum, Hintere Bleiweißstraße 15",
      },
      {
        day: "Donnerstag",
        time: "18:45 – 20:00",
        location:
          "Turnhalle, Adam-Kraft-Realschule, Lutherplatz 8 (U-Bahn Maffeiplatz, Ausgang Zwinglistr.)",
      },
    ],
  },
  {
    title: "Wirbelsäulen­gymnastik",
    slots: [
      {
        day: "Montag",
        time: "17:30 – 18:30",
        location: "Turnhalle, Sperberschule, Sperberstr. 85",
      },
    ],
  },
  {
    title: "Gymnastik und Tanz",
    slots: [
      {
        day: "Montag",
        time: "19:45 – 21:00",
        location: "Turnhalle, Sperberschule, Sperberstr. 85",
      },
    ],
  },
  {
    title: "Fitness und Ausdauer für Ältere",
    slots: [
      {
        day: "Montag",
        time: "9:30 – 10:30",
        location:
          "Pfarrsaal Verklärung Christi, Sperberstr. 53, Ecke Ajtoschstr.",
      },
    ],
  },
  {
    title: "Sport für Ältere",
    slots: [
      {
        day: "Mittwoch",
        time: "9:30 – 10:30",
        location:
          "Pfarrsaal Verklärung Christi, Sperberstr. 53, Ecke Ajtoschstr.",
      },
    ],
  },
];

const contacts = [
  {
    name: "Sabine Fuchs",
    role: "Abteilungsleiterin",
    mobile: "0157 746 079 63",
  },
];
---

<Layout
  title="Gesundheitssport"
  description="Gesundheitssport bei DJK Sparta Noris Nürnberg: Herzsport, Wirbelsäulengymnastik, Gymnastik & Tanz, Fitness für Ältere. Kursangebote, Termine & Kontakt."
>
  <main>
    <DepartmentHero
      title="Aktiv"
      accent="gesund."
      lead="Sanftes Training, gezielte Gesundheitsübungen und die richtige Balance aus Bewegung und Wohlbefinden — unser Programm für alle, die gesund und fit bleiben wollen."
    />

    <section class="bg-sparta-ink px-6 py-16 text-white md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Programm"
        title="Angebote"
      />

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          offers.map((offer) => (
            <article class="flex flex-col overflow-hidden border border-white/12 bg-white/8 text-white">
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display m-0 text-[26px] leading-[1.05] font-bold tracking-[-0.01em] uppercase">
                  {offer.title}
                </h3>

                <div class="mt-5 flex flex-col gap-4 border-t border-white/12 pt-5">
                  {offer.slots.map((slot) => (
                    <div>
                      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                        <span class="font-display text-[15px] font-bold tracking-[0.5px] uppercase">
                          {slot.day}
                        </span>
                        <span class="font-mono text-[13px]">{slot.time}</span>
                      </div>
                      <div class="mt-1.5 text-[13px] leading-normal text-white/85">
                        {slot.location}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <DepartmentCTA
      eyebrow="Probestunde gefällig?"
      title="Beweg dich"
      accent="mit uns."
      lead="Schau einfach in einem unserer Kurse vorbei oder schreib uns vorab eine Nachricht."
      actions={[
        {
          label: "Ruf uns an",
          href: "tel:+4915774607963",
          variant: "ink",
        },
        { label: "Zur Kontaktseite", href: "/contact", variant: "outline" },
      ]}
    />

    <section class="bg-sparta-ink px-6 py-16 text-white md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Ansprechpartner"
        title="Dein Kontakt zur Abteilung"
      />
      <CoachesGrid people={contacts} variant="dark" />
    </section>
  </main>
</Layout>
