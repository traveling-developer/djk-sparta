---
import contactImage from "../../assets/contact.webp";
import indiacaImage from "../../assets/indiaca.webp";

import ContactCard from "../../components/ContactCard.astro";
import GoogleMaps from "../../components/GoogleMaps.astro";
import Header from "../../components/Header.astro";
import Menu from "../../components/indiaca/Menu.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Sponsors, { SponsorsCategory } from "../../components/Sponsors.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Indiaca">
  <main>
    <Header title="Indiaca" imageMetadata={indiacaImage} />

    <!-- TODO <Menu path="indiaca" /> -->

    <div class="hero">
      <div class="hero-content">
        <div class="mx-10 my-5 text-lg">
          <p>
            Indiaca ist ein Rückschlagspiel ähnlich dem Volleyball und bietet
            somit ideale Bedingungen für Powerplay am Ball. Es ist ein absolut
            begeisternder Mannschaftssport für Jung und Alt!<br />
            Vom Studenten über den Midager bis hin zu sportlichen Menschen jedes Alters.
          </p>
          <br />
          <p>
            Insbesondere Interessenten, die einmal etwas Neues, eine eher
            weniger bekannte Teamsportart suchen, möchten wir zum Reinschnuppern
            in den actionreichen und schnell erlernbaren Indiacasport einladen.
          </p>
          <br />
          <p class="font-semibold">
            Gerne begrüßen wir Interessenten/innen am Hallentraining -
            wöchentlich montags ab 20.00h - bei uns.
          </p>
          <br />
          <p>
            Wetterbedingt und nach Absprache bieten wir nun ab üblicherweise ab
            dem monat April zusätzlich auch ein Training outdoor auf unserem
            Sportgelände an: Trainingstag ist Mittwoch.
          </p>
          <br />
          <p>
            Wer also Lust auf eine neue Sportart hat, ist in unserem Verein, dem
            einzigen in Nürnberg mit dem Sportangebot Indiaca goldrichtig und
            herzlich willkommen...
          </p>
        </div>
      </div>
    </div>

    <div>
      <SectionHeader title="Kontakt" imageMetadata={contactImage} />

      <div class="mt-5 mb-10 flex flex-wrap justify-center gap-6">
        <ContactCard
          title="Herbert Langfritz (Ansprechpartner)"
          mail="indiaca@djkspartanoris.de"
        />
      </div>
    </div>

    <div>
      <SectionHeader
        title="Weitere Informationen"
        imageMetadata={contactImage}
      />

      <div class="mt-5 mb-10 flex flex-wrap justify-center gap-6">
        <div
          class="card bg-spartaGray w-72 text-white shadow-md shadow-gray-400 sm:w-[28rem]"
        >
          <div class="card-body">
            <h2 class="card-title">Diese Seite befindet sich im Aufbau</h2>
            <p class="mt-2">
              Unsere Indiaca-Seite wird derzeit überarbeitet. Informationen zu
              Trainingszeiten, Turnieren und weiteren Aktivitäten findest du bis
              auf Weiteres auf unserer alten externen Website.
            </p>
            <div class="card-actions mt-4 justify-end">
              <a
                href="https://indiaca-nuernberg.jimdoweb.com/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-outline hover:border-spartaRed hover:bg-spartaRed transition duration-300 ease-in-out hover:-translate-y-1"
              >
                Zur Indiaca-Website →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <GoogleMaps
      latitude={49.416459843204485}
      longitude={11.068967769662304}
      zoom={15}
      title="DJK Sparta Noris Nürnberg e.V."
      hasInfoWindow={true}
      displayInfoWindowOnClick={false}
      infoWindowContent="DJK Sparta Noris Nürnberg e.V.<br/>Wacholderweg 60<br/>90441 Nürnberg"
    />
  </main>
</Layout>
