---
import Layout from "../../layouts/Layout.astro";
import DepartmentHero from "../../components/department/DepartmentHero.astro";
import DepartmentSectionHeader from "../../components/department/DepartmentSectionHeader.astro";
import DepartmentCTA from "../../components/department/DepartmentCTA.astro";
import CoachesGrid from "../../components/department/CoachesGrid.astro";
import GoogleMap from "../../components/GoogleMap.astro";

interface Slot {
  day: string;
  time: string;
  note?: string;
}

interface Offer {
  title: string;
  slots: Slot[];
  location: string;
}

const offers: Offer[] = [
  {
    title: "Hallentraining",
    slots: [{ day: "Montag", time: "ab 20:00" }],
    location: "Schulsporthalle · ganzjährig",
  },
  {
    title: "Outdoor-Training",
    slots: [
      {
        day: "Mittwoch",
        time: "nach Absprache",
        note: "ab April · wetterabhängig",
      },
    ],
    location: "Sparta-Sportgelände, Wacholderweg 60",
  },
];

const contacts = [
  {
    name: "Herbert Langfritz",
    role: "Ansprechpartner",
    email: "indiaca@djkspartanoris.de",
  },
];
---

<Layout
  title="Indiaca"
  description="Indiaca bei DJK Sparta Noris Nürnberg: Rückschlagspiel ähnlich Volleyball — schnell erlernbar, actionreich, für jedes Alter. Hallen- und Outdoor-Training."
>
  <main>
    <DepartmentHero
      title="Indiaca"
      accent="Bei Sparta."
      lead="Rückschlagspiel ähnlich dem Volleyball — schnell erlernbar, actionreich und ein begeisternder Mannschaftssport für Jung und Alt."
    />

    <section class="bg-sparta-ink px-6 py-16 text-white md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Trainingszeiten"
        title="Wann wir spielen"
      />

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {
          offers.map((offer) => (
            <article class="flex flex-col overflow-hidden border border-white/12 bg-white/8 text-white">
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display m-0 text-[26px] leading-[1.05] font-bold tracking-[-0.01em] uppercase">
                  {offer.title}
                </h3>

                <div class="mt-5 flex flex-col gap-4 border-t border-white/12 pt-5">
                  {offer.slots.map((slot) => (
                    <div>
                      <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                        <span class="font-display text-[15px] font-bold tracking-[0.5px] uppercase">
                          {slot.day}
                        </span>
                        <span class="font-mono text-[13px]">{slot.time}</span>
                      </div>
                      {slot.note && (
                        <div class="mt-1 font-mono text-[11px] tracking-[1px] text-white/55 uppercase">
                          {slot.note}
                        </div>
                      )}
                    </div>
                  ))}
                  <div class="text-[13px] leading-[1.5] text-white/85">
                    {offer.location}
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="bg-sparta-paper px-6 py-16 md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        eyebrow="Was ist Indiaca?"
        title="Powerplay am Ball"
      />

      <div class="grid max-w-3xl grid-cols-1 gap-5">
        <p class="text-sparta-ink-soft m-0 text-[17px] leading-[1.6]">
          Indiaca ist ein Rückschlagspiel ähnlich dem Volleyball und bietet
          somit ideale Bedingungen für Powerplay am Ball. Es ist ein absolut
          begeisternder Mannschaftssport für Jung und Alt! Vom Studenten über
          den Midager bis hin zu sportlichen Menschen jedes Alters.
        </p>
        <p class="text-sparta-ink-soft m-0 text-[17px] leading-[1.6]">
          Insbesondere Interessenten, die einmal etwas Neues, eine eher weniger
          bekannte Teamsportart suchen, möchten wir zum Reinschnuppern in den
          actionreichen und schnell erlernbaren Indiacasport einladen.
        </p>
        <p class="text-sparta-ink-soft m-0 text-[17px] leading-[1.6]">
          Wer also Lust auf eine neue Sportart hat, ist in unserem Verein, dem
          einzigen in Nürnberg mit dem Sportangebot Indiaca goldrichtig und
          herzlich willkommen...
        </p>
      </div>
    </section>

    <DepartmentCTA
      eyebrow="Lust auf was Neues?"
      title="Schau"
      accent="vorbei."
      lead="Komm einfach zum Hallentraining am Montag oder schreib uns vorab eine Nachricht."
      actions={[
        {
          label: "Schreib uns",
          href: "mailto:indiaca@djkspartanoris.de",
          variant: "ink",
        },
        { label: "Zur Kontaktseite", href: "/contact", variant: "outline" },
      ]}
    />

    <section class="bg-sparta-ink px-6 py-16 text-white md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Ansprechpartner"
        title="Dein Kontakt zur Abteilung"
      />
      <CoachesGrid people={contacts} variant="dark" />
    </section>

    <section class="bg-sparta-paper px-6 py-16 md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        eyebrow="Mehr erfahren"
        title="Weitere Informationen"
      />

      <div class="grid grid-cols-1 items-start gap-8 md:grid-cols-[1.4fr_1fr]">
        <p class="text-sparta-ink-soft m-0 max-w-2xl text-[17px] leading-[1.6]">
          Unsere ausführliche Indiaca-Seite wird derzeit überarbeitet.
          Informationen zu Turnieren und weiteren Aktivitäten findest du bis auf
          Weiteres auf unserer bisherigen externen Website.
        </p>

        <div class="flex md:justify-end">
          <a
            href="https://indiaca-nuernberg.jimdoweb.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-sparta-ink font-display inline-flex items-center justify-between gap-4 px-6 py-4.5 text-sm font-bold tracking-[2px] text-white uppercase no-underline transition-colors hover:bg-black"
          >
            <span>Zur Indiaca-Website</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
