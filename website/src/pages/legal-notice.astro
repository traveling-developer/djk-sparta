---
import Layout from "../layouts/Layout.astro";
import DepartmentHero from "../components/department/DepartmentHero.astro";
import DepartmentSectionHeader from "../components/department/DepartmentSectionHeader.astro";
import { club } from "../lib/club";
---

<Layout title="Impressum">
  <main>
    <DepartmentHero
      title="Klein"
      accent="Gedruckt."
      lead="Angaben gemäß § 5 TMG, Vertretung, Register und verantwortliche Stelle."
    />

    <section class="bg-sparta-paper px-6 py-16 md:px-14 md:py-22.5">
      <DepartmentSectionHeader eyebrow="§ 5 TMG" title="Pflichtangaben" />

      <dl
        class="grid max-w-4xl grid-cols-1 gap-x-12 gap-y-10 md:grid-cols-2"
      >
        <div>
          <dt
            class="text-sparta-red mb-3 text-[11px] font-semibold tracking-[2px] uppercase"
          >
            Anbieter
          </dt>
          <dd
            class="text-sparta-ink-soft font-mono text-[13.5px] leading-[1.85]"
          >
            {club.name}<br />
            {club.address.street}<br />
            {club.address.postalCode} {club.address.city}
          </dd>
        </div>

        <div>
          <dt
            class="text-sparta-red mb-3 text-[11px] font-semibold tracking-[2px] uppercase"
          >
            Vertreten durch
          </dt>
          <dd
            class="text-sparta-ink-soft font-mono text-[13.5px] leading-[1.85]"
          >
            Dieter Wolfsberger · 1. Vorstand<br />
            Thomas Uebler · 2. Vorstand
          </dd>
        </div>

        <div>
          <dt
            class="text-sparta-red mb-3 text-[11px] font-semibold tracking-[2px] uppercase"
          >
            Register
          </dt>
          <dd
            class="text-sparta-ink-soft font-mono text-[13.5px] leading-[1.85]"
          >
            Vereinsregister VR 1023<br />
            Amtsgericht Nürnberg<br />
            Steuer-Nr. 241/107/80113
          </dd>
        </div>

        <div>
          <dt
            class="text-sparta-red mb-3 text-[11px] font-semibold tracking-[2px] uppercase"
          >
            Kontakt
          </dt>
          <dd
            class="text-sparta-ink-soft [&_a]:hover:text-sparta-red font-mono text-[13.5px] leading-[1.85] [&_a]:no-underline"
          >
            <a href={club.contact.phoneTel}>{club.contact.phone}</a><br />
            <a href={club.contact.emailMailto}
              >{club.contact.email.replace("@", "(at)")}</a
            >
          </dd>
        </div>

        <div>
          <dt
            class="text-sparta-red mb-3 text-[11px] font-semibold tracking-[2px] uppercase"
          >
            Redaktionell verantwortlich
          </dt>
          <dd
            class="text-sparta-ink-soft font-mono text-[13.5px] leading-[1.85]"
          >
            Dieter Wolfsberger · 1. Vorstand
          </dd>
        </div>

        <div>
          <dt
            class="text-sparta-red mb-3 text-[11px] font-semibold tracking-[2px] uppercase"
          >
            Verbraucherstreitbeilegung
          </dt>
          <dd class="text-sparta-ink-soft max-w-100 text-[14px] leading-[1.65]">
            Wir sind nicht bereit oder verpflichtet, an
            Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle
            teilzunehmen.
          </dd>
        </div>
      </dl>
    </section>
  </main>
</Layout>
