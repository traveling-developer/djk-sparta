---
import Layout from "../../layouts/Layout.astro";
import { news } from "../../lib/news";
import { createSlug } from "../../lib/convenience";
import typeWriterImage from "../../assets/typewriter.webp";
import SectionHeader from "../../components/SectionHeader.astro";
import { Picture } from "astro:assets";
import { PortableText } from "astro-portabletext";
import PortableTextLink from "../../components/news/PortableTextLink.astro";

export async function getStaticPaths() {
  return news.map((news) => ({
    params: {
      slug: createSlug(news.title!),
    },
    props: news,
  }));
}

const article = Astro.props;

// Inline-Bilder sind im Schema vorerst deaktiviert; bei Reaktivierung
// PortableTextImage wieder unter type: { image: ... } einhängen.
const ptComponents = {
  mark: { link: PortableTextLink },
};
---

<Layout title={article.title!} description={article.title!}>
  <main>
    <SectionHeader title="News" imageMetadata={typeWriterImage} />

    <div class="my-5 flex flex-col items-center text-center">
      <h2 class="mt-5 mb-8 p-0.5 text-xl font-semibold sm:text-2xl">
        {article.category === "table-tennis" && "🏓 "}
        {article.category === "soccer" && "⚽ "}
        {article.category === "general" && "🤝 "}
        {article.category === "health-sport" && "🧘‍♀️ "}
        {article.category === "indiaca" && "🪶 "}
        {article.category === "tennis" && "🎾 "}{article.title}
      </h2>
      <div class="mx-5 sm:w-2/3 lg:w-1/2 xl:w-1/2 2xl:w-2/5">
        <div class="article-body text-justify">
          <PortableText
            value={article.content ?? []}
            components={ptComponents}
          />
        </div>
        {
          (article as any).imageUrl && (
            <div class="mt-5">
              <Picture
                src={(article as any).imageUrl}
                alt="Ein passendes Bild zu diesem Artikel"
                inferSize={true}
                widths={[400, 800, 1200]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 66vw, 50vw"
                formats={["webp"]}
                class="w-full rounded-lg"
              />
            </div>
          )
        }
        <div class="mt-5 text-left text-sm">
          Published at: {article.releaseDate}
        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Portable Text erzeugt <p>-Absätze statt pre-line; Abstand zwischen Absätzen. */
  .article-body :global(p) {
    margin: 0 0 1.2em;
  }
  .article-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .article-body :global(h2),
  .article-body :global(h3),
  .article-body :global(h4) {
    text-align: left;
    font-weight: 600;
    line-height: 1.3;
    margin: 1.4em 0 0.5em;
  }
  .article-body :global(h2) {
    font-size: 1.25rem;
  }
  .article-body :global(h3) {
    font-size: 1.125rem;
  }
  .article-body :global(h4) {
    font-size: 1rem;
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    text-align: left;
    margin: 0 0 1.2em;
    padding-left: 1.5em;
  }
  .article-body :global(ul) {
    list-style: disc;
  }
  .article-body :global(ol) {
    list-style: decimal;
  }
  .article-body :global(blockquote) {
    border-left: 3px solid #d81e28;
    margin: 0 0 1.2em;
    padding-left: 1em;
    font-style: italic;
  }
</style>
