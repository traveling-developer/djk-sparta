---
import Layout from "../../layouts/Layout.astro";
import { news } from "../../lib/news";
import { createSlug } from "../../lib/convenience";
import { Picture } from "astro:assets";
import { PortableText } from "astro-portabletext";
import PortableTextLink from "../../components/news/PortableTextLink.astro";

export async function getStaticPaths() {
  return news.map((news) => ({
    params: {
      slug: createSlug(news.title!),
    },
    props: news,
  }));
}

type Article = (typeof news)[number] & { imageUrl?: string };

const article = Astro.props as Article;

const categoryLabel: Record<string, string> = {
  general: "Allgemein",
  soccer: "Fußball",
  "health-sport": "Gesundheitssport",
  indiaca: "Indiaca",
  tennis: "Tennis",
  "table-tennis": "Tischtennis",
};

function formatDate(iso: string | undefined): string {
  if (!iso) return "";
  const d = new Date(iso);
  return d.toLocaleDateString("de-DE", {
    day: "2-digit",
    month: "2-digit",
    year: "numeric",
  });
}

const category = categoryLabel[article.category ?? ""] ?? article.category;
---

<Layout title={article.title!} description={article.title!}>
  <main class="bg-sparta-paper px-6 py-14 md:px-14 md:py-10">
    <!-- Article -->
    <article class="mx-auto max-w-180">
      <a
        href="/#news"
        class="font-display text-sparta-mute hover:text-sparta-red mb-8 inline-flex items-center gap-2 text-[11px] font-bold tracking-[2px] uppercase no-underline hover:opacity-100"
      >
        <span aria-hidden="true">←</span> Zurück zu den Meldungen
      </a>

      <div class="news-meta">
        {category && <span class="news-cat">{category}</span>}
        {article.releaseDate && (
          <span class="news-date">· {formatDate(article.releaseDate)}</span>
        )}
      </div>

      <h1 class="article-title">{article.title}</h1>

      {
        article.imageUrl && (
          <div class="border-sparta-line mb-9 overflow-hidden border">
            <Picture
              src={article.imageUrl}
              alt="Ein passendes Bild zu diesem Artikel"
              inferSize={true}
              widths={[400, 800, 1200]}
              sizes="(max-width: 720px) 100vw, 720px"
              formats={["webp"]}
              class="block w-full"
            />
          </div>
        )
      }

      <div class="article-body">
        {article.content}
      </div>

      <div class="border-sparta-line mt-12 border-t pt-8">
        <a
          href="/#news"
          class="font-display text-sparta-mute hover:text-sparta-red inline-flex items-center gap-2 text-[11px] font-bold tracking-[2px] uppercase no-underline hover:opacity-100"
        >
          <span aria-hidden="true">←</span> Zurück zu den Meldungen
        </a>
      </div>
    </article>
  </main>
</Layout>

<style>
  .news-meta {
    display: flex;
    gap: 8px;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .news-cat {
    color: #d81e28;
  }
  .news-date {
    color: #6a6a70;
  }

  .article-title {
    font-family: "Oswald", "Arial Narrow", sans-serif;
    font-size: clamp(30px, 4vw, 44px);
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 28px;
    color: #0c0c0e;
  }

  .article-body {
    font-size: 16px;
    color: #1a1a1d;
    line-height: 1.7;
    white-space: pre-line;
  }
</style>
