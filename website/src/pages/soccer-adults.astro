---
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
import ContactCard from "../components/ContactCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import TeamCard from "../components/soccer/TeamCard.astro";

import soccerImage from "../assets/soccer.webp";
import contactImage from "../assets/contact.webp";
import teamImage from "../assets/team.webp";

import { getTeams } from "../lib/soccer/teams";
import SoccerHeadOfDepartment from "../components/contact/SoccerHeadOfDepartment.astro";
import Events from "../components/soccer/Events.astro";
var teams = await getTeams(false);
---

<Layout title="Fußball">
  <main>
    <Header title="Fußball - Herren" imageMetadata={soccerImage} />

    <div class="mt-5 mb-10 flex flex-wrap justify-center gap-6">
      <Events />
      <div
        class="card bg-spartaGray w-72 text-white shadow-md shadow-gray-400 sm:w-[28rem]"
      >
        <div class="card-body">
          <h2 class="card-title">Trainingszeiten</h2>
          <p>AH <br /> Donnerstag 19:00 - 20:30 Uhr</p>
          <p>
            1. Mannschaft <br /> Dienstag & Donnerstag 18:45 - 20:45 Uhr
          </p>
          <p>PM Bonifaz <br /> Mittwoch 18:30 - 20:30 Uhr</p>
        </div>
      </div>
    </div>

    <div>
      <SectionHeader title="Mannschaften" imageMetadata={teamImage} />

      <div class="mt-5 mb-10 flex flex-wrap justify-center gap-6">
        {
          teams.map((team) => (
            <TeamCard
              name={team.name}
              league={team.league}
              rank={team.rank}
              goalDifference={team.goalDifference}
              link={team.link}
            />
          ))
        }
        <div class="h-full">
          <div
            class="card via-spartaRed h-full w-76.5 bg-linear-to-b from-[#8b0000] to-[#ff6666] text-white shadow-md shadow-gray-400 sm:w-80"
          >
            <div class="card-body p-4">
              <h2 class="card-title justify-center">Walking Football</h2>
              <p>
                Kicken im Gehen <br />
                Wer spielt, gewinnt an Lebensfreude<br />
                Egal in welchem Tempo!
              </p>
              <div class="card-actions mt-auto justify-center">
                <a
                  href="/walking-football"
                  class="btn btn-outline hover:border-spartaGray hover:bg-spartaGray mt-4 transition duration-300 ease-in-out hover:-translate-y-1 hover:text-white"
                  >mehr Infos</a
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- TODO <div>
            <SectionHeader title="Kontakt" imageMetadata={contactImage} />

            <div class="flex flex-wrap justify-center gap-6 mb-10 mt-5">
                <SoccerHeadOfDepartment />
                <ContactCard title="TBD (2. Abteilungsleiter)" mail="..." />
            </div>
        </div> -->
  </main>
</Layout>
