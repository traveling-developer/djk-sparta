---
import Layout from "../layouts/Layout.astro";
import DepartmentHero from "../components/department/DepartmentHero.astro";
import DepartmentSectionHeader from "../components/department/DepartmentSectionHeader.astro";
import CoachesGrid from "../components/department/CoachesGrid.astro";
import DepartmentCTA from "../components/department/DepartmentCTA.astro";
import TeamsGrid from "../components/soccer/TeamsGrid.astro";
import TrainingAndFixturesSection from "../components/soccer/TrainingAndFixturesSection.astro";
import { getMatches } from "../lib/soccer/matches";
import { getTeams } from "../lib/soccer/teams";
import { germanNumberWord } from "../lib/convenience";

const rawTeams = await getTeams(false);

const dynamicTeams = rawTeams.map((t) => ({
  name: t.name,
  league: t.league,
  place: t.rank,
  played: t.played,
  w: t.w,
  d: t.d,
  l: t.l,
  pts: t.pts,
  link: t.link,
  linkLabel: "BFV-Spielplan",
}));

const staticTeams = [
  {
    name: "Alt Herren",
    league: "Ohne Spielbetrieb",
    place: "n.a.",
    pts: "n.a.",
  },
  {
    name: "Walking Football",
    league: "Ohne Spielbetrieb",
    place: "n.a.",
    pts: "n.a.",
    link: "/walking-football",
    linkLabel: "Mehr Infos",
  },
];

const teams = [...dynamicTeams, ...staticTeams];

const teamCountWord = germanNumberWord(teams.length);

const fixtures = (await getMatches())
  .slice(0, 5)
  .map((m) => ({
    date: m.date,
    time: m.time,
    home: m.homeTeam,
    away: m.guestTeam,
  }));

const week = [
  [],
  [{ team: "Herren I", time: "18:45-20:30" }],
  [{ team: "PM Bonifaz", time: "18:30-20:30" }],
  [
    { team: "Herren I", time: "18:45-20:30" },
    { team: "AH", time: "19:00-20:30" },
  ],
  [],
  [],
  [],
];

const coaches = [
  {
    name: "Thomas Uebler",
    role: "2. Vorstand",
    email: "tu@djkspartanoris.de",
  },
  {
    name: "Oliver Rauh",
    role: "Alt Herren - 1. Abteilungsleiter",
    mobile: "0178 5540770",
  },
  {
    name: "Thorsten Lechner",
    role: "Alt Herren - 2. Abteilungsleiter",
    mobile: "01728733059",
  },
];

const referees = [
  { name: "Hans-Georg Grell" },
  { name: "Erna Grell" },
  { name: "Maximilian Hasler" },
  { name: "Marcel Schwager" },
  { name: "Bianca Seyschab" },
  { name: "Dieter Wolfsberger" },
];
---

<Layout title="Fußball Herren">
  <main>
    <DepartmentHero
      title="Fußball"
      accent="Herren."
      lead={`${teamCountWord} Mannschaften, ein Wappen. Von der Landesliga bis zur Altherrenrunde — Leidenschaft für das runde Leder auf Sparta-Art.`}
    />

    <TrainingAndFixturesSection week={week} fixtures={fixtures} />

    <section class="bg-sparta-paper px-6 py-16 md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        eyebrow="Mannschaften"
        title={`${teamCountWord} Teams · ein Verein`}
      />
      <TeamsGrid teams={teams} />
    </section>

    <section
      class="bg-sparta-ink px-6 pt-16 pb-8 text-white md:px-14 md:pt-22.5 md:pb-10"
    >
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Ansprechpartner"
        title="Unser Team neben dem Platz"
      />
      <CoachesGrid people={coaches} variant="dark" />
    </section>

    <section
      class="bg-sparta-ink px-6 pt-8 pb-16 text-white md:px-14 md:pt-10 md:pb-22.5"
    >
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Schiedsrichter"
        title="Die Pfeife in der Hand"
      />
      <CoachesGrid people={referees} variant="dark" />
    </section>

    <DepartmentCTA
      eyebrow="Neuer Spieler? Neuer Trainer?"
      title="Schnür die"
      accent="Schuhe."
      lead="Komm zum Probetraining. Erste zwei Einheiten sind kostenlos — bring Freunde, bring Bälle, bring gute Laune."
      watermark="11"
      actions={[
        {
          label: "Trainer kontaktieren",
          href: "mailto:ms@djkspartanoris.de",
          variant: "ink",
        },
        { label: "Zur Kontaktseite", href: "/contact", variant: "outline" },
      ]}
    />
  </main>
</Layout>
