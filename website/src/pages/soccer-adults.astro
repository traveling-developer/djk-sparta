---

<Layout title="Fußball Herren">
  <main>
    <DepartmentHero
      title="Fußball"
      accent="Herren."
      lead="Drei Mannschaften, ein Wappen. Von der Landesliga bis zur Altherrenrunde — Leidenschaft für das runde Leder auf Sparta-Art."
    />

    <TrainingAndFixturesSection week={week} fixtures={fixtures} />

    <section class="bg-sparta-paper px-6 py-16 md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        eyebrow="Mannschaften"
        title="Drei Teams · ein Verein"
      />
      <TeamsGrid teams={teams} />
    </section>

    <section
      class="bg-sparta-ink px-6 pt-16 pb-8 text-white md:px-14 md:pt-22.5 md:pb-10"
    >
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Ansprechpartner"
        title="Unser Team neben dem Platz"
      />
      <CoachesGrid people={coaches} variant="dark" />
    </section>

    <section
      class="bg-sparta-ink px-6 pt-8 pb-16 text-white md:px-14 md:pt-10 md:pb-22.5"
    >
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Schiedsrichter"
        title="Die Pfeife in der Hand"
      />
      <CoachesGrid people={referees} variant="dark" />
    </section>

    <DepartmentCTA
      eyebrow="Neuer Spieler? Neuer Trainer?"
      title="Schnür die"
      accent="Schuhe."
      lead="Komm zum Probetraining. Erste zwei Einheiten sind kostenlos — bring Freunde, bring Bälle, bring gute Laune."
      watermark="11"
      actions={[
        {
          label: "Trainer kontaktieren",
          href: "mailto:ms@djkspartanoris.de",
          variant: "ink",
        },
        { label: "Zur Kontaktseite", href: "/contact", variant: "outline" },
      ]}
    />
  </main>
</Layout>
