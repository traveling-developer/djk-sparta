---
import Layout from "../layouts/Layout.astro";
import DepartmentHero from "../components/department/DepartmentHero.astro";
import DepartmentSectionHeader from "../components/department/DepartmentSectionHeader.astro";
import TrainingAndFixturesSection from "../components/soccer/TrainingAndFixturesSection.astro";
import CoachesGrid from "../components/department/CoachesGrid.astro";
import DepartmentCTA from "../components/department/DepartmentCTA.astro";
import TeamsGrid from "../components/soccer/TeamsGrid.astro";

import { getTeams } from "../lib/soccer/teams";
import { club } from "../lib/club";
import { germanNumberWord } from "../lib/convenience";
import Sponsors, { SponsorsCategory } from "../components/Sponsors.astro";

const rawTeams = await getTeams(true);

const dynamicTeams = rawTeams.map((t) => ({
  name: t.name,
  league: t.league,
  place: t.rank,
  played: t.played,
  w: t.w,
  d: t.d,
  l: t.l,
  pts: t.pts,
  link: t.link,
  linkLabel: "BFV-Spielplan",
}));

const staticTeams = [
  {
    name: "G-Junioren",
    league: "Ohne Spielbetrieb",
    place: "n.a.",
    pts: "n.a.",
  },
  {
    name: "Bambinis",
    league: "Ohne Spielbetrieb",
    place: "n.a.",
    pts: "n.a.",
  },
];

const teams = [...dynamicTeams, ...staticTeams];

const teamCountWord = germanNumberWord(teams.length);

const week = [
  // Mo
  [
    { team: "Bambini", time: "17:15-17:45" },
    { team: "G-Jugend", time: "18:00-19:00" },
    { team: "F1-Jugend", time: "17:00-18:30" },
    { team: "F2-Jugend", time: "17:30-19:00" },
  ],
  // Di
  [
    { team: "E1-Jugend", time: "17:00-18:30" },
    { team: "E2-Jugend", time: "17:00-18:30" },
    { team: "D-Jugend", time: "17:30-19:00" },
  ],
  // Mi
  [{ team: "F1-Jugend", time: "17:00-18:30" }],
  // Do
  [
    { team: "E1-Jugend", time: "17:00-18:30" },
    { team: "E2-Jugend", time: "17:00-18:30" },
  ],
  // Fr
  [
    { team: "D-Jugend", time: "16:00-17:30" },
    { team: "F2-Jugend", time: "17:30-19:00" },
  ],
  [], // Sa
  [], // So
];

const coaches = [
  {
    name: "Robert Scherret",
    role: "Jugendleiter",
    mobile: "0152 0711 5488",
  },
  {
    name: "Aylin Karaca",
    role: "Jugendleiterin",
    mobile: "-",
  },
];
---

<Layout title="Fußball Junioren">
  <main>
    <DepartmentHero
      title="Fußball"
      accent="Junioren."
      lead="Vom ersten Ballkontakt bis zum großen Spielfeld — bei Sparta wachsen junge Kicker über den Verein hinaus. Fünf Trainingstage, eine Leidenschaft."
    />

    <TrainingAndFixturesSection
      trainingsEyebrow="Trainingszeiten · Wacholderplatz"
      trainingsTitle="Trainingswoche"
      week={week}
      trainingCols={3}
    />

    <section class="bg-sparta-paper px-6 py-16 md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        eyebrow="Mannschaften"
        title={`${teamCountWord} Teams · unser Nachwuchs`}
      />
      <TeamsGrid teams={teams} />
    </section>

    <section class="bg-sparta-ink px-6 py-16 text-white md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Ansprechpartner"
        title="Unser Team neben dem Platz"
      />
      <CoachesGrid people={coaches} variant="dark" />
    </section>

    <DepartmentCTA
      eyebrow="Probetraining für Kids?"
      title="Schnür die"
      accent="Stollen."
      lead="Bring Sportzeug, Trinkflasche und gute Laune mit."
      watermark="11"
      actions={[
        {
          label: "Schreib uns",
          href: club.contact.emailMailto,
          variant: "ink",
        },
        { label: "Zur Kontaktseite", href: "/contact", variant: "outline" },
      ]}
    />

    <Sponsors category={SponsorsCategory.soccer} />
  </main>
</Layout>
