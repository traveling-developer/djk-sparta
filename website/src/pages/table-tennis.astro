---
import Layout from "../layouts/Layout.astro";
import DepartmentHero from "../components/department/DepartmentHero.astro";
import DepartmentSectionHeader from "../components/department/DepartmentSectionHeader.astro";
import TrainingAndFixturesSection from "../components/soccer/TrainingAndFixturesSection.astro";
import CoachesGrid from "../components/department/CoachesGrid.astro";
import DepartmentCTA from "../components/department/DepartmentCTA.astro";
import TableTennisTeamsGrid from "../components/tableTennis/TableTennisTeamsGrid.astro";
import Location from "../components/department/Location.astro";
import News from "../components/News.astro";
import Sponsors, { SponsorsCategory } from "../components/Sponsors.astro";

import { getTeams } from "../lib/tableTennis/teams";
import { getMatches } from "../lib/tableTennis/matches";

const teams = await getTeams();
const rawMatches = await getMatches();

const fixtures = rawMatches.slice(0, 5).map((m) => ({
  date: m.date,
  time: m.time,
  home: m.homeTeam,
  away: m.guestTeam,
  isHome: /sparta/i.test(m.homeTeam),
  venue: /sparta/i.test(m.homeTeam) ? "Sperberschule" : "—",
}));

const week = [
  [],
  [{ team: "Alle Leistungsklassen", time: "ab 18:00" }],
  [{ team: "alle Leistungsklassen", time: "ab 18:00" }],
  [],
  [{ team: "alle Leistungsklassen", time: "ab 18:00" }],
  [],
  [],
];

const coaches = [
  {
    name: "Jürgen Fietz",
    role: "1. Abteilungsleiter",
    email: "juergen.fietz@djkspartanoris.de",
    phone: "0911 542 611",
    mobile: "0170 337 303 5",
  },
  {
    name: "Armin Ufert",
    role: "2. Abteilungsleiter",
    email: "armin.ufert@gmx.de",
    mobile: "+49 176 78102208",
  },
  {
    name: "Anton Nagatkin",
    role: "2. Abteilungsleiter",
    mobile: "+49 176 74729697",
  },
];
---

<Layout
  title="Tischtennis"
  description="Tischtennis in Nürnberg bei DJK Sparta Noris: Training (Di, Mi, Fr). Infos, Termine & Kontakt hier!"
>
  <main>
    <DepartmentHero
      title="Tischtennis"
      accent="Bei Sparta."
      lead="Schnell, präzise, gesellig. Spielbetrieb in mehreren Mannschaften, offenes Training für alle Spielstärken — Tischtennis auf Sparta-Art."
    />

    <TrainingAndFixturesSection
      trainingsEyebrow="Trainingszeiten · Sperberschule"
      trainingsTitle="Trainingswoche"
      fixturesEyebrow="Nächste Spiele"
      fixturesTitle="Termine"
      week={week}
      fixtures={fixtures}
    />

    <section class="bg-sparta-paper px-6 py-16 md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        eyebrow="Mannschaften"
        title="Punktspielbetrieb"
      />
      <TableTennisTeamsGrid teams={teams} />
    </section>

    <News category="table-tennis" />

    <Location
      titleTop="Sperber"
      titleAccent="Halle."
      latitude={49.43233666177542}
      longitude={11.088991326381146}
      mapTitle="DJK Sparta Noris TT"
      infoWindowContent='<h1 class="text-xl">DJK Sparta Tischtennis</h1><p>Eingang über den Pausenhof der Sperberschule.<br/>Zugang über die Langobardenstraße.</p>'
    >
      <Fragment slot="address">
        Schulsporthalle Sperberschule<br />
        Sperberstr. 85<br />
        Eingang Langobardenstr.<br />
        90461 Nürnberg
      </Fragment>
      <Fragment slot="hint">
        Eingang über den Pausenhof der Sperberschule. Zugang über die
        Langobardenstraße.
      </Fragment>
    </Location>

    <DepartmentCTA
      eyebrow="Probetraining gefällig?"
      title="Schläger"
      accent="raus."
      lead="Komm einfach vorbei!"
      watermark="TT"
      actions={[
        {
          label: "Schreib uns",
          href: "mailto:juergen.fietz@djkspartanoris.de",
          variant: "ink",
        },
        { label: "Zur Kontaktseite", href: "/contact", variant: "outline" },
      ]}
    />

    <section class="bg-sparta-ink px-6 py-16 text-white md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Ansprechpartner"
        title="Das Team hinter unserem Erfolg"
      />
      <CoachesGrid people={coaches} variant="dark" />
    </section>

    <Sponsors category={SponsorsCategory.tableTennis} />
  </main>
</Layout>
