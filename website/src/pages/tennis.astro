---
import Layout from "../layouts/Layout.astro";
import DepartmentHero from "../components/department/DepartmentHero.astro";
import DepartmentSectionHeader from "../components/department/DepartmentSectionHeader.astro";
import TrainingAndFixturesSection from "../components/soccer/TrainingAndFixturesSection.astro";
import CoachesGrid from "../components/department/CoachesGrid.astro";
import DepartmentCTA from "../components/department/DepartmentCTA.astro";
import Location from "../components/department/Location.astro";
import TennisTeamsGrid from "../components/tennis/TennisTeamsGrid.astro";
import { club } from "../lib/club";

const week = [
  [],
  [{ team: "Alle Leistungsklassen", time: "16:00-20:00" }],
  [],
  [{ team: "Alle Leistungsklassen", time: "16:00-20:00" }],
  [],
  [],
  [],
];

const teams = [
  {
    name: "Herren U30",
    league: "-",
    rank: "-",
    points: "-",
  },
  {
    name: "Herren U40",
    league: "-",
    rank: "-",
    points: "-",
  },
];

const coaches = [
  {
    name: "Markus Krämer",
    role: "1. Abteilungsleiter",
    mobile: "0179 59 56 101",
  },
  {
    name: "Alexander Kolodziej",
    mobile: "0176 402 064 56",
  },
  {
    name: "Wilhelm Hess",
    mobile: "0172 864 953 1",
  },
  {
    name: "Egor Meisler",
    mobile: "0176 476 970 35",
  },
  {
    name: "Edward Akinshyn",
    mobile: "0157 817 789 87",
  },
];
---

<Layout title="Tennis">
  <main>
    <DepartmentHero
      title="Tennis"
      accent="Bei Sparta."
      lead="Zwei Herren-Mannschaften, drei Outdoor-Plätze, zwei Trainingstage. Tennis im Grünen am Sparta-Vereinsheim — vom Punktspielbetrieb bis zum Feierabend-Match."
    />

    <TrainingAndFixturesSection
      trainingsEyebrow="Trainingszeiten · Wacholderweg"
      trainingsTitle="Trainingswoche"
      week={week}
    />

    <section class="bg-sparta-paper px-6 py-16 md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        eyebrow="Mannschaften"
        title="Punktspielbetrieb"
      />
      <TennisTeamsGrid teams={teams} />
    </section>

    <section class="bg-sparta-ink px-6 py-16 text-white md:px-14 md:py-22.5">
      <DepartmentSectionHeader
        variant="dark"
        eyebrow="Ansprechpartner"
        title="Unser Team am Platz"
      />
      <CoachesGrid people={coaches} variant="dark" />
    </section>

    <Location
      titleTop="Wacholder"
      titleAccent="Plätze."
      latitude={club.coordinates.latitude}
      longitude={club.coordinates.longitude}
      mapTitle={club.name}
      infoWindowContent={`${club.name}<br/>${club.address.street}<br/>${club.address.postalCode} ${club.address.city}`}
    >
      <Fragment slot="address">
        Sparta-Tennisanlage<br />
        {club.address.street}<br />
        {club.address.postalCode}{" "}{club.address.city} · {
          club.address.district
        }
      </Fragment>
    </Location>

    <DepartmentCTA
      eyebrow="Spiellust?"
      title="Schlag"
      accent="auf."
      lead="Bring deine Schuhe und gute Laune mit. Einen Schläger leihen wir dir gerne."
      actions={[
        {
          label: "Schreib uns",
          href: club.contact.emailMailto,
          variant: "ink",
        },
        { label: "Zur Kontaktseite", href: "/contact", variant: "outline" },
      ]}
    />
  </main>
</Layout>
